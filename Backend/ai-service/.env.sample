# Server Configuration
PORT=8000

# MongoDB (Analytics & App Data)
MONGO_URI=mongodb://localhost:27017/foodtech

# Neo4j (Knowledge Graph & Entity Relationships)
NEO4J_URI=neo4j+s://<YOUR_AURA_INSTANCE_ID>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_super_secret_neo4j_password
NEO4J_DATABASE=neo4j
NEO4J_AURA_INSTANCE=<YOUR_AURA_INSTANCE_ID>

# Qdrant (Vector Store for RAG)
QDRANT_URL=http://localhost:6333

# Security
JWT_SECRET=your_super_secret_jwt_key

# AI Providers
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

#core-api Server for user-data
INTERNAL_BASE_URL= http://localhost:3000/api/internal